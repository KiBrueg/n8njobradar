                  {
                      "id":  "node_llm",
                      "name":  "LLM: FIRMA_GRUND generieren",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       660,
                                       -100
                                   ],
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "https://openrouter.ai/api/v1/chat/completions",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "Authorization",
                                                                                         "value":  "=Bearer {{ $env.OPENROUTER_API_KEY }}"
                                                                                     },
                                                                                     {
                                                                                         "name":  "content-type",
                                                                                         "value":  "application/json"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "contentType":  "raw",
                                         "rawContentType":  "application/json",
                                         "body":  "={{ JSON.stringify({ model: \u0027qwen/qwen3-30b-a3b-instruct-2507\u0027, max_tokens: 60, messages: [{ role: \u0027system\u0027, content: \u0027/no_think\\nSchreibe eine kurze Phrase (max. 15 Wörter), die nach dem Wort \"weil\" steht. Klein beginnen. KEIN \"weil\" am Anfang. Kein Punkt. Beispiel: \"mich Ihr Fokus auf Automatisierung und der pragmatische Tech-Stack überzeugt haben\"\u0027 }, { role: \u0027user\u0027, content: \u0027Firma: \u0027 + $json.company_name + \u0027\\nStelle: \u0027 + $json.job_title + \u0027\\nInfo: \u0027 + (($json.parsed_json \u0026\u0026 typeof $json.parsed_json === \u0027object\u0027) ? ($json.parsed_json.summary || \u0027\u0027) : \u0027\u0027) }] }) }}",
                                         "options":  {
                                                         "timeout":  30000
                                                     }
                                     }
                  },
                  {
                      "id":  "node_build",
                      "name":  "Code: Anschreiben bauen",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       880,
                                       -100
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "jsCode":  "const llmRaw = $input.item.json.choices?.[0]?.message?.content || \u0027\u0027;\nconst grund = llmRaw.replace(/\u003cthink\u003e[\\s\\S]*?\u003c\\/think\u003e/gi, \u0027\u0027).trim().replace(/^weil\\s+/i, \u0027\u0027) || \u0027mich Ihre Arbeit mit Automatisierung und KI überzeugt hat\u0027;\n\nconst job = $(\u0027DB: Jobs mit Email holen\u0027).item.json;\nconst firma = job.company_name || \u0027Ihr Unternehmen\u0027;\nconst stelle = job.job_title || \u0027die ausgeschriebene Stelle\u0027;\n\nconst body = `\u003cdiv style=\"font-family: Arial, sans-serif; font-size: 15px; color: #1a1a1a; max-width: 520px; line-height: 1.7;\"\u003e\n\n\u003cp style=\"margin: 0 0 20px 0;\"\u003eGuten Tag,\u003c/p\u003e\n\n\u003cp style=\"margin: 0 0 20px 0;\"\u003eich schreibe Ihnen bezüglich der Stelle als \u003cstrong\u003e${stelle}\u003c/strong\u003e bei ${firma}.\u003c/p\u003e\n\n\u003cp style=\"margin: 0 0 20px 0;\"\u003eIch bin Automation Engineer aus Berlin (Python, n8n, LLM-Integration) und würde mich freuen, wenn Sie einen Blick in meinen Lebenslauf im Anhang werfen — ich bewerbe mich, weil ${grund}.\u003c/p\u003e\n\n\u003cp style=\"margin: 0 0 32px 0;\"\u003eVielen Dank für Ihre Zeit.\u003c/p\u003e\n\n\u003cp style=\"margin: 0 0 32px 0;\"\u003eMit freundlichen Grüßen,\u003cbr\u003e\u003cstrong\u003eKirill Brüggemann\u003c/strong\u003e\u003cbr\u003e\u003cspan style=\"font-size: 13px; color: #666;\"\u003eGitHub: \u003ca href=\"https://github.com/KiBrueg\" style=\"color: #555;\"\u003egithub.com/KiBrueg\u003c/a\u003e\u003c/span\u003e\u003c/p\u003e\n\n\u003chr style=\"border: none; border-top: 1px solid #e8e8e8; margin: 0 0 12px 0;\"\u003e\n\u003cp style=\"margin: 0; font-size: 12px; color: #999; line-height: 2.4;\"\u003e\n\u003ca href=\"https://drive.google.com/file/d/1HwbI0zcSySikQdV2yEJuaoeU-hyNaDVy/view\" style=\"color: #555; text-decoration: none;\"\u003e📄 Lebenslauf\u003c/a\u003e\n\u0026nbsp;·\u0026nbsp;\n\u003ca href=\"https://drive.google.com/file/d/1G2uANtdZywakvzyt4JJyA73tI4ilzO5W/view\" style=\"color: #555; text-decoration: none;\"\u003e📊 Portfolio\u003c/a\u003e\n\u0026nbsp;·\u0026nbsp;\n\u003ca href=\"https://github.com/KiBrueg\" style=\"color: #555; text-decoration: none;\"\u003eGitHub\u003c/a\u003e\n\u0026nbsp;·\u0026nbsp;\n\u003ca href=\"https://linkedin.com/in/ki-brueg-2520033bb\" style=\"color: #555; text-decoration: none;\"\u003eLinkedIn\u003c/a\u003e\n\u003c/p\u003e\n\n\u003c/div\u003e`;\n\nreturn {\n  job_id: job.id,\n  contact_email: job.contact_email,\n  subject: `Bewerbung als ${stelle} (m/w/d) — Kirill Brüggemann`,\n  body,\n  firma,\n  stelle\n};"
                                     }
