                  {
                      "id":  "node_db_fetch",
                      "name":  "DB: Jobs mit Email holen",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       220,
                                       0
                                   ],
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT * FROM (\n  SELECT DISTINCT ON (j.contact_email)\n    j.id, c.name AS company_name, j.job_title, j.location, j.contact_email,\n    j.job_type, j.working_hours, je.parsed_json, j.created_at\n  FROM jobs j\n  LEFT JOIN companies c ON c.tenant_id = j.tenant_id AND c.company_id = j.company_id\n  LEFT JOIN LATERAL (\n    SELECT parsed_json FROM job_events WHERE job_id = j.id ORDER BY created_at DESC LIMIT 1\n  ) je ON true\n  WHERE j.contact_email IS NOT NULL\n    AND j.auto_applied_at IS NULL\n    AND j.current_stage NOT IN (\u0027rejected\u0027, \u0027withdrawn\u0027)\n    AND j.contact_email NOT IN (\n      SELECT contact_email FROM jobs\n      WHERE auto_applied_at IS NOT NULL AND contact_email IS NOT NULL\n    )\n    AND j.contact_email !~* \u0027(sbv|betriebsrat|datenschutz|noreply|no-reply)\u0027\n    AND j.job_title !~* \u0027(marketing|social media|sales|vertrieb|recruiting)\u0027\n    AND COALESCE((je.parsed_json-\u003e\u003e\u0027relevance_score\u0027)::int, 60) \u003e= 50\n  ORDER BY j.contact_email, j.created_at DESC\n) q ORDER BY created_at DESC LIMIT 10;",
                                         "options":  {

                                                     }
                                     },
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "Tvuhat51UDCzKwnE",
                                                           "name":  "Postgres account"
                                                       }
                                      }
                  },
                  {
                      "id":  "node_if_jobs",
                      "name":  "IF: Jobs vorhanden",
                      "type":  "n8n-nodes-base.if",
                      "typeVersion":  2.2,
                      "position":  [
                                       440,
                                       0
                                   ],
                      "parameters":  {
                                         "conditions":  {
                                                            "options":  {
                                                                            "caseSensitive":  true,
                                                                            "leftValue":  "",
                                                                            "typeValidation":  "strict",
                                                                            "version":  2
                                                                        },
