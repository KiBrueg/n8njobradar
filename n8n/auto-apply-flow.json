                                         "jsCode":  "const item = $input.item;\nif (item.binary \u0026\u0026 item.binary.data) {\n  item.binary.data.fileName = \u0027Lebenslauf_Kirill_Brueggemann.pdf\u0027;\n  item.binary.data.mimeType = \u0027application/pdf\u0027;\n}\nreturn { json: $(\u0027Code: Anschreiben bauen\u0027).item.json, binary: item.binary };"
                                     },
                      "notes":  "Restores email json (subject/body/contact) after HTTP node replaced it; names the attachment."
