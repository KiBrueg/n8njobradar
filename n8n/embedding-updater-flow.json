{
    "name":  "JobRadar -- Flow 9: Embedding Updater",
    "nodes":  [
                  {
                      "parameters":  {

                                     },
                      "id":  "n_trigger",
                      "name":  "Manual Trigger",
                      "type":  "n8n-nodes-base.manualTrigger",
                      "typeVersion":  1,
                      "position":  [
                                       200,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT j.id, j.job_title, c.name AS company_name, j.location, j.summary FROM jobs j LEFT JOIN companies c ON c.company_id = j.company_id AND c.tenant_id = j.tenant_id WHERE j.embedding IS NULL ORDER BY j.created_at DESC LIMIT 300",
                                         "options":  {

                                                     }
                                     },
                      "id":  "n_fetch",
                      "name":  "DB: Jobs Without Embedding",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       420,
                                       300
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "Tvuhat51UDCzKwnE",
                                                           "name":  "Postgres account"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "batchSize":  1,
                                         "options":  {

                                                     }
                                     },
                      "id":  "n_split",
                      "name":  "Split In Batches",
                      "type":  "n8n-nodes-base.splitInBatches",
                      "typeVersion":  3,
                      "position":  [
                                       640,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "https://api.jina.ai/v1/embeddings",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "Authorization",
                                                                                         "value":  "=Bearer {{ $env.JINA_API_KEY }}"
                                                                                     },
                                                                                     {
                                                                                         "name":  "Content-Type",
                                                                                         "value":  "application/json"
                                                                                     },
                                                                                     {
                                                                                         "name":  "Accept",
                                                                                         "value":  "application/json"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "contentType":  "raw",
                                         "rawContentType":  "application/json",
                                         "body":  "={{ JSON.stringify({ model: \u0027jina-embeddings-v3\u0027, task: \u0027retrieval.passage\u0027, dimensions: 1024, input: [[$json.job_title, $json.company_name, $json.location, $json.summary].filter(Boolean).join(\u0027 \u0027)] }) }}",
                                         "options":  {
                                                         "timeout":  30000
                                                     }
                                     },
                      "id":  "n_embed",
                      "name":  "Jina: Generate Embedding",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       860,
                                       300
                                   ],
                      "notes":  "Calls jina-embeddings-v3 (free tier: 1M tokens/month).\nInput: concatenated job_title + company + location + summary.\n1024-dim vector stored in jobs.embedding (pgvector)."
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Pull original job row from the fetch node\nconst job = $(\u0027DB: Jobs Without Embedding\u0027).item.json;\n\n// Jina returns: { data: [{ embedding: [float, ...] }] }\nconst vec = $input.item.json.data[0].embedding;\n\nif (!vec || !vec.length) {\n  throw new Error(\u0027Jina returned empty embedding for job \u0027 + job.id);\n}\n\n// pgvector expects \u0027[0.1,0.2,...]\u0027 string format\nreturn [{ json: {\n  job_id:    job.id,\n  job_title: job.job_title,\n  embedding: \u0027[\u0027 + vec.join(\u0027,\u0027) + \u0027]\u0027\n}}];"
                                     },
                      "id":  "n_format",
                      "name":  "Format Vector",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1080,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "UPDATE jobs SET embedding = $1::vector WHERE id = $2::uuid",
                                         "options":  {
                                                         "queryReplacement":  "={{ $json.embedding }},={{ $json.job_id }}"
                                                     }
                                     },
                      "id":  "n_save",
                      "name":  "DB: Save Embedding",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.5,
                      "position":  [
                                       1300,
                                       300
                                   ],
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "Tvuhat51UDCzKwnE",
                                                           "name":  "Postgres account"
                                                       }
                                      },
                      "notes":  "Parameterized UPDATE — $1::vector, $2::uuid.\nSafe: embedding data comes from Jina, not user input."
                  },
                  {
                      "id":  "39bda26d-74f0-4674-9b11-454e031da97b",
                      "name":  "Schedule: Daily 07:30",
                      "type":  "n8n-nodes-base.scheduleTrigger",
                      "typeVersion":  1.1,
                      "position":  [
                                       200,
                                       140
                                   ],
                      "parameters":  {
                                         "rule":  {
                                                      "interval":  [
                                                                       {
                                                                           "field":  "days",
                                                                           "daysInterval":  1,
                                                                           "triggerAtHour":  7,
                                                                           "triggerAtMinute":  30
                                                                       }
                                                                   ]
                                                  }
                                     },
                      "notes":  "Runs after all morning scrapers (04:30-07:15) — embeds the day\u0027s new jobs. TEMP set to trigger backfill now, will be restored to 07:30."
                  }
              ],
