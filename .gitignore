# ============================================================
# JobRadar — .gitignore
# ============================================================

# --- Secrets & credentials ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
secrets/

# --- Session summaries (contain real IPs, API keys, emails) ---
sessions/

# --- Personal documents (CV, cover letters, drafts — never on GitHub) ---
spec/base-lebenslauf.yaml
spec/lebenslauf-template.html
spec/lebenslauf*/
spec/anschreiben*/
spec/motivationsschreiben*/
spec/cover-letter*/
docs/lebenslauf*/
docs/anschreiben*/
personal/
bewerbung/
*.lebenslauf.*
*.anschreiben.*
*_cv.*
*_resume.*

# --- Internal session & Claude context files ---
NEXT_SESSION.md
.claude/

# --- Generated outputs ---
outputs/
*.bak
*.sql.gz
n8n/*-clean.json

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
