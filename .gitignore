# ============================================================
# JobRadar — .gitignore
# ============================================================

# --- Secrets & credentials ---
.env
.env.*
!.env.example
*.key
*.pem
*.p12
secrets/
.mcp.json

# --- Session summaries (contain real IPs, API keys, emails) ---
sessions/

# --- Financial documents (invoices, NDA, bank details — never on GitHub) ---
client-handwerk/finanzen/

# --- Personal documents (CV, cover letters, drafts — never on GitHub) ---
spec/base-lebenslauf.yaml
spec/lebenslauf-template.html
spec/lebenslauf*/
spec/anschreiben*/
spec/motivationsschreiben*/
spec/cover-letter*/
docs/lebenslauf*/
docs/anschreiben*/
personal/
bewerbung/
*.lebenslauf.*
*.anschreiben.*
*_cv.*
*_resume.*

# --- Internal session & Claude context files ---
NEXT_SESSION.md
.claude/

# --- Generated outputs ---
outputs/
*.bak
*.sql.gz
n8n/*-clean.json

# --- Temp / working files (patch scripts, live exports, test payloads) ---
*_live.json
*_patched.json
*_patch.json
*_fixed.json
*-fixed.json
*_current.json
*-current.json
test_payload.json
notion_patch_*.json
scripts/deploy_payloads/
scripts/update_prompt_vps.py
gas/sheets-writer-v2.gs

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
