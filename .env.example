# ============================================================
# JobRadar — Required Environment Variables
# ============================================================
# Copy this file to your n8n host and add values to your
# n8n instance's .env (or however you manage env vars).
# These variables are consumed via $env.VAR_NAME in n8n Code nodes.
# ============================================================

# ------------------------------------------------------------
# LLM API
# ------------------------------------------------------------

# DeepSeek API key (OpenAI-compatible endpoint)
# Get at: https://platform.deepseek.com/api_keys
# Used by: "DeepSeek API" node in all flows
DEEPSEEK_API_KEY=sk-...

# Full system prompt for the JobRadar parser (single line, escaped quotes)
# Content: spec/prompt-system.txt — collapse to one line before pasting:
#   python3 -c "import sys; t=open('spec/prompt-system.txt').read(); print(t.replace('\\n','\\\\n').replace('\"','\\\\\"'))"
# Used by: "DeepSeek API" node (messages[0].content)
JOBRADAR_SYSTEM_PROMPT="You are a precise job-data extraction engine..."

# ------------------------------------------------------------
# Postgres — JobRadar database
# ------------------------------------------------------------
# These go into n8n as a "Postgres" credential named "JobRadar Postgres".
# Attach this credential to the "DB: Write All" node after workflow import.

JOBRADAR_POSTGRES_HOST=localhost        # or container name if n8n is in Docker
JOBRADAR_POSTGRES_PORT=5432
JOBRADAR_POSTGRES_DB=jobradar
JOBRADAR_POSTGRES_USER=hub
JOBRADAR_POSTGRES_PASSWORD=...         # never commit the real value

# ------------------------------------------------------------
# n8n Webhook — Manual Input (Flow 3)
# ------------------------------------------------------------
# Webhook path is hardcoded in the workflow node as: jobradar-manual
# Full URL: https://<your-n8n-host>/webhook/jobradar-manual
# Auth: none (add n8n webhook auth in production if exposed publicly)

# Test curl:
#   curl -s -X POST https://<n8n-host>/webhook/jobradar-manual \
#     -H "Content-Type: application/json" \
#     -d '{"raw_text":"Job description text here"}'

# ------------------------------------------------------------
# Optional — Future flows (not yet implemented)
# ------------------------------------------------------------

# Gmail OAuth credentials → configure in n8n UI as "Gmail OAuth2" credential
# mail.de IMAP → configure in n8n UI as "IMAP Email" credential
# Google Calendar API → configure in n8n UI as "Google Calendar OAuth2" credential
